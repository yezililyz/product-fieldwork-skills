{
  "name": "product-fieldwork-skills-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing 57 Product Fieldwork skills (product/growth/career jobs) as native MCP resources, prompts, and tools.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "product-management",
    "growth",
    "product-strategy",
    "career",
    "claude",
    "cursor",
    "continue"
  ],
  "homepage": "https://github.com/yezililyz/product-fieldwork-skills/tree/main/mcp-server",
  "bugs": "https://github.com/yezililyz/product-fieldwork-skills/issues",
  "license": "UNLICENSED",
  "author": {
    "name": "Yezi",
    "url": "https://yezi-hub.web.app"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yezililyz/product-fieldwork-skills.git",
    "directory": "mcp-server"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "product-fieldwork-skills-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "prepack": "npm run build && npm run sync:skills",
    "sync:skills": "node scripts/sync-skills.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.6.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
